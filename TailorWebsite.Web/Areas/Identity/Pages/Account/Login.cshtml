@page
@model LoginModel

@{
    ViewData["Title"] = "Logowanie";
    ViewData["FullWidth"] = true;
}

<div class="auth-split">
    <!-- Lewa strona - dekoracja -->
    <div class="auth-split__left d-none d-lg-flex">
        <div class="auth-split__overlay"></div>
        <div class="auth-split__brand position-relative">
            <div class="mb-5">
                <i class="bi bi-scissors" style="font-size:3rem; color:#c5a059;"></i>
                <h2 class="text-white fw-bold mt-3 mb-2">Usługi Krawieckie</h2>
                <p class="text-white-50">Indywidualne szycie na miarę</p>
            </div>
            <blockquote class="auth-quote">
                "Dobry krawiec szyje nie tylko ubranie,<br>lecz pewność siebie swojego klienta."
            </blockquote>
        </div>
    </div>
    <!-- Prawa strona - formularz -->
    <div class="auth-split__right d-flex align-items-center justify-content-center">
        <div class="auth-form-wrap">
            <div class="text-center mb-5">
                <div class="auth-icon-wrap mb-3"><i class="bi bi-person-circle"></i></div>
                <h2 class="fw-bold">Witaj ponownie</h2>
                <p class="text-muted">Zaloguj się do swojego konta</p>
            </div>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 mb-3 small" role="alert"></div>
                <div class="mb-4">
                    <label asp-for="Input.Email" class="auth-label">Adres e-mail</label>
                    <div class="auth-input-group">
                        <i class="bi bi-envelope auth-input-icon"></i>
                        <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.Password" class="auth-label">Hasło</label>
                    <div class="auth-input-group">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input asp-for="Input.Password" class="form-control auth-input" autocomplete="current-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-4">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted small">Zapamiętaj mnie</label>
                </div>
                <button id="login-submit" type="submit" class="btn btn-gold w-100 py-3 fw-bold rounded-pill mb-4">
                    Zaloguj się <i class="bi bi-arrow-right ms-2"></i>
                </button>
                <p class="text-center text-muted small mb-0">
                    Nie masz konta?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-warning fw-semibold text-decoration-none">Zarejestruj się</a>
                </p>
            </form>
            @if (Model.ExternalLogins?.Count > 0)
            {
                <hr class="my-4" />
                <p class="text-center text-muted small mb-3">lub zaloguj przez</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-light rounded-pill px-4 fw-semibold" name="provider" value="@provider.Name">
                                <i class="bi bi-box-arrow-in-right me-2"></i>@provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
