@model TailorWebsite.ViewModels.VM.AddPhoneNumberViewModel
@{
    ViewData["Title"] = "Dane kontaktowe";
}

<section class="position-relative overflow-hidden rounded-4 text-white dark-blue mb-4 shadow p-4">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h5 class="text-warning text-uppercase letter-spacing-2 mb-2">Kontakt</h5>
            <h1 class="display-5 fw-bold mb-2">Numer telefonu</h1>
            <p class="text-white-50 mb-0">Dodaj numer, abyśmy mogli skontaktować się z Tobą w sprawie zamówień.</p>
        </div>
        <div class="col-lg-4 text-end d-none d-lg-block">
            <i class="bi bi-telephone-fill text-warning" style="font-size: 5rem; opacity: 0.6;"></i>
        </div>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-4 p-lg-5">
                <form asp-action="AddPhoneNumber" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-3 small" role="alert"></div>

                    <div class="mb-5">
                        <label asp-for="PhoneNumber" class="form-label fw-bold text-secondary text-uppercase small letter-spacing-1">Numer telefonu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 rounded-start-pill ps-3"><i class="bi bi-telephone text-muted"></i></span>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg border-0 bg-light rounded-end-pill shadow-none" placeholder="+48 123 456 789" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill fw-semibold px-4">Anuluj</a>
                        <button type="submit" class="btn btn-gold btn-lg rounded-pill fw-bold flex-fill shadow-sm">
                            <i class="bi bi-check-lg me-2"></i>Zapisz numer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
