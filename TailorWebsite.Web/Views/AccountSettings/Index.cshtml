@{
    ViewData["Title"] = "Ustawienia konta";
    ViewData["FullWidth"] = true;
}


<!-- ===== HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-4" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="profile-badge mb-3 d-inline-block">Panel użytkownika</span>
                <h1 class="display-5 fw-bold text-white mb-2">Ustawienia konta</h1>
                <p class="text-white-50 mb-0">Zarządzaj bezpieczeństwem, danymi kontaktowymi i preferencjami swojego konta.</p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-sliders profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>


<section class="profile-section">
<div class="container">
    <div class="row g-4">
        
 
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm service-card text-center">
                <div class="card-body p-4 d-flex flex-column align-items-center">
                    <div class="bg-light rounded-circle p-3 mb-3 text-warning icon-box">
                        <i class="bi bi-shield-lock-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Hasło i bezpieczeństwo</h4>
                    <p class="text-muted small mb-4">Zaktualizuj swoje hasło, aby zapewnić bezpieczeństwo konta.</p>
                    
                    <div class="mt-auto w-100">
                        <a asp-action="ChangePassword" class="btn btn-outline-dark w-100 stretched-link">Zmień hasło</a>
                    </div>
                </div>
            </div>
        </div>

        
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm service-card text-center">
                <div class="card-body p-4 d-flex flex-column align-items-center">
                    <div class="bg-light rounded-circle p-3 mb-3 text-warning icon-box">
                        <i class="bi bi-telephone-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Dane kontaktowe</h4>
                    <p class="text-muted small mb-4">Dodaj lub zaktualizuj numer telefonu do kontaktu w sprawie zamówień.</p>
                    
                    <div class="mt-auto w-100">
                        <a asp-action="AddPhoneNumber" class="btn btn-outline-dark w-100 stretched-link">Zarządzaj numerem</a>
                    </div>
                </div>
            </div>
        </div>

   
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm service-card danger-card text-center">
                <div class="card-body p-4 d-flex flex-column align-items-center">
                    <div class="bg-danger-subtle rounded-circle p-3 mb-3 text-danger icon-box">
                        <i class="bi bi-exclamation-triangle-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2 text-danger">Usuń konto</h4>
                    <p class="text-muted small mb-4">Trwale usuń swoje konto i wszystkie powiązane dane. Tej operacji nie można cofnąć.</p>
                    <div class="mt-auto w-100">
                        <a asp-controller="Profile" asp-action="DeleteAccount" class="btn btn-outline-danger w-100 stretched-link">Usuń konto</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm service-card text-center bg-light mt-2">
                <div class="card-body p-3 d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-arrow-left-circle fs-5 text-muted"></i>
                    <a asp-controller="Profile" asp-action="Index" class="stretched-link text-decoration-none text-muted fw-semibold">
                        Wróć do profilu głównego
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
</section>
