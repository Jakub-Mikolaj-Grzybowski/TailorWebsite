@model TailorWebsite.ViewModels.VM.ChangePasswordViewModel
@{
    ViewData["Title"] = "Zmiana hasła";
    ViewData["FullWidth"] = true;
}

<!-- ===== HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-4" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="profile-badge mb-3 d-inline-block">Bezpieczeństwo</span>
                <h1 class="display-5 fw-bold text-white mb-2">Zmiana hasła</h1>
                <p class="text-white-50 mb-0">Wybierz mocne hasło, aby chronić swoje konto.</p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-shield-lock-fill profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>

<!-- ===== CONTENT ===== -->
<section class="profile-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">

                <div class="profile-card card border-0 shadow-sm">
                    <div class="card-body p-4 p-lg-5">

                        <div class="mb-4">
                            <span class="section-tag">Ustawienia konta</span>
                            <h4 class="fw-bold mb-0">Zmień hasło</h4>
                        </div>

                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4 small" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="OldPassword" class="auth-label">Aktualne hasło</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                        <i class="bi bi-lock" style="color:#c5a059;"></i>
                                    </span>
                                    <input asp-for="OldPassword"
                                           class="form-control border-0 bg-light"
                                           style="height:3rem; border-radius:0 .6rem .6rem 0;"
                                           placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="OldPassword" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="NewPassword" class="auth-label">Nowe hasło</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                        <i class="bi bi-lock-fill" style="color:#c5a059;"></i>
                                    </span>
                                    <input asp-for="NewPassword"
                                           class="form-control border-0 bg-light"
                                           style="height:3rem; border-radius:0 .6rem .6rem 0;"
                                           placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="auth-label">Powtórz nowe hasło</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                        <i class="bi bi-shield-check" style="color:#c5a059;"></i>
                                    </span>
                                    <input asp-for="ConfirmPassword"
                                           class="form-control border-0 bg-light"
                                           style="height:3rem; border-radius:0 .6rem .6rem 0;"
                                           placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="d-grid gap-2 mt-2">
                                <button type="submit" class="btn btn-gold btn-lg rounded-pill fw-bold">
                                    <i class="bi bi-check-lg me-2"></i>Zmień hasło
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                                    <i class="bi bi-arrow-left me-1"></i> Anuluj
                                </a>
                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
