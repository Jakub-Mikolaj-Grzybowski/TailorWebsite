@model IEnumerable<TailorWebsite.ViewModels.VM.SizeCreateViewModel>
@{
    ViewData["Title"] = "Moje wymiary";
    ViewData["FullWidth"] = true;
}

<!-- ===== HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-5" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="profile-badge mb-3 d-inline-block">Profil krawiecki</span>
                <h1 class="display-5 fw-bold text-white mb-3">Moje wymiary</h1>
                <p class="text-white-50 mb-0">Zarządzaj swoimi wymiarami, abyśmy mogli idealnie dopasować Twoje kreacje.</p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-rulers profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>

<!-- ===== CONTENT ===== -->
<section class="profile-section">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="section-tag">Twoje konto</span>
                <h2 class="section-title mb-0">Zapisane wymiary</h2>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-1"></i> Powrót
                </a>
                <a asp-action="Create" class="btn btn-gold rounded-pill px-4">
                    <i class="bi bi-plus-lg me-1"></i> Dodaj wymiary
                </a>
            </div>
        </div>

        <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var s in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="profile-card service-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4 d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div>
                                    <small class="text-muted text-uppercase fw-bold" style="letter-spacing:0.07em;">Data pomiaru</small>
                                    <h5 class="fw-bold mb-0">@s.CreatedAt.ToString("dd.MM.yyyy")</h5>
                                    <small class="text-muted">godz. @s.CreatedAt.ToString("HH:mm")</small>
                                </div>
                                <div class="profile-card__icon-wrap flex-shrink-0">
                                    <i class="bi bi-clipboard-data"></i>
                                </div>
                            </div>

                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block mb-1">Klatka</small>
                                        <span class="fw-bold fs-5">@s.ChestCircumference</span> <small class="text-muted">cm</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block mb-1">Talia</small>
                                        <span class="fw-bold fs-5">@s.WaistCircumference</span> <small class="text-muted">cm</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block mb-1">Biodra</small>
                                        <span class="fw-bold fs-5">@s.HipCircumference</span> <small class="text-muted">cm</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3 text-center">
                                        <small class="text-muted d-block mb-1">Rękaw</small>
                                        <span class="fw-bold fs-5">@s.SleeveLength</span> <small class="text-muted">cm</small>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-auto">
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post"
                                      onsubmit="return confirm('Czy na pewno chcesz usunąć ten wpis?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill">
                                        <i class="bi bi-trash me-1"></i> Usuń wpis
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm text-center py-5 rounded-4">
                    <div class="card-body">
                        <div class="profile-card__icon-wrap mx-auto mb-4" style="width:5rem;height:5rem;font-size:2rem;">
                            <i class="bi bi-rulers"></i>
                        </div>
                        <h3 class="fw-bold">Brak zapisanych wymiarów</h3>
                        <p class="text-muted mb-4">Nie dodałeś jeszcze żadnych wymiarów. Uzupełnij je, aby ułatwić proces zamawiania.</p>
                        <a asp-action="Create" class="btn btn-gold px-4 py-2 rounded-pill">
                            Dodaj pierwsze wymiary
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>

    </div>
</section>

