@model TailorWebsite.ViewModels.VM.SizeCreateViewModel
@{
    ViewData["Title"] = "Dodaj wymiary";
    ViewData["FullWidth"] = true;
}

<!-- ===== HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-5" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="profile-badge mb-3 d-inline-block">Profil krawiecki</span>
                <h1 class="display-5 fw-bold text-white mb-3">Nowe pomiary</h1>
                <p class="text-white-50 mb-0">Wprowadź aktualne wymiary w centymetrach.</p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-rulers profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>

<!-- ===== CONTENT ===== -->
<section class="profile-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <div class="profile-card card border-0 shadow-sm">
                    <div class="card-body p-4 p-lg-5">

                        <div class="mb-4">
                            <span class="section-tag">Wymiary ciała</span>
                            <h4 class="fw-bold mb-0">Wprowadź pomiary</h4>
                        </div>

                        <form asp-action="Create" method="post" novalidate>
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>

                            <div class="row g-3">

                                <!-- Klatka piersiowa -->
                                <div class="col-md-6">
                                    <label asp-for="ChestCircumference" class="auth-label">Klatka piersiowa</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                            <i class="bi bi-arrow-left-right" style="color:#c5a059;"></i>
                                        </span>
                                        <input asp-for="ChestCircumference"
                                               class="form-control border-0 bg-light"
                                               style="height:3rem;"
                                               type="number" step="1" placeholder="np. 96" />
                                        <span class="input-group-text bg-light border-0" style="border-radius:0 .6rem .6rem 0; color:#6c757d;">cm</span>
                                    </div>
                                    <span asp-validation-for="ChestCircumference" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <!-- Talia -->
                                <div class="col-md-6">
                                    <label asp-for="WaistCircumference" class="auth-label">Talia</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                            <i class="bi bi-arrow-left-right" style="color:#c5a059;"></i>
                                        </span>
                                        <input asp-for="WaistCircumference"
                                               class="form-control border-0 bg-light"
                                               style="height:3rem;"
                                               type="number" step="1" placeholder="np. 78" />
                                        <span class="input-group-text bg-light border-0" style="border-radius:0 .6rem .6rem 0; color:#6c757d;">cm</span>
                                    </div>
                                    <span asp-validation-for="WaistCircumference" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <!-- Biodra -->
                                <div class="col-md-6">
                                    <label asp-for="HipCircumference" class="auth-label">Biodra</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                            <i class="bi bi-arrow-left-right" style="color:#c5a059;"></i>
                                        </span>
                                        <input asp-for="HipCircumference"
                                               class="form-control border-0 bg-light"
                                               style="height:3rem;"
                                               type="number" step="1" placeholder="np. 102" />
                                        <span class="input-group-text bg-light border-0" style="border-radius:0 .6rem .6rem 0; color:#6c757d;">cm</span>
                                    </div>
                                    <span asp-validation-for="HipCircumference" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <!-- Rękaw -->
                                <div class="col-md-6">
                                    <label asp-for="SleeveLength" class="auth-label">Długość rękawa</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0" style="border-radius:.6rem 0 0 .6rem;">
                                            <i class="bi bi-arrow-left-right" style="color:#c5a059;"></i>
                                        </span>
                                        <input asp-for="SleeveLength"
                                               class="form-control border-0 bg-light"
                                               style="height:3rem;"
                                               type="number" step="1" placeholder="np. 62" />
                                        <span class="input-group-text bg-light border-0" style="border-radius:0 .6rem .6rem 0; color:#6c757d;">cm</span>
                                    </div>
                                    <span asp-validation-for="SleeveLength" class="text-danger small mt-1 d-block"></span>
                                </div>

                            </div>

                            <!-- Akcje -->
                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-gold btn-lg rounded-pill fw-bold">
                                    <i class="bi bi-save me-2"></i>Zapisz wymiary
                                </button>
                                <a asp-action="List" class="btn btn-outline-secondary rounded-pill">
                                    <i class="bi bi-arrow-left me-1"></i> Anuluj
                                </a>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function(){
            const $form = $("form");
            $form.removeData("validator").removeData("unobtrusiveValidation");
            $.validator.unobtrusive.parse($form);
            if ($form.data('validator')) {
                $form.validate().settings.onkeyup = function (element) { $(element).valid(); };
            }
        })();
    </script>
}

