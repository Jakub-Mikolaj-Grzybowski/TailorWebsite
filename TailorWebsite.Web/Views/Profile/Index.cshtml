@model TailorWebsite.ViewModels.VM.ProfileViewModel
@{
    ViewData["Title"] = "Mój profil";
    ViewData["FullWidth"] = true;
    var initials = string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name.Substring(0, 1).ToUpper();
}

<!-- ===== PROFILE HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-5" style="z-index:1;">
        <div class="row align-items-center">
            <!-- Avatar + info -->
            <div class="col-lg-8 d-flex flex-column flex-md-row align-items-md-center gap-4">
                <div class="profile-avatar flex-shrink-0">@initials</div>
                <div>
                    <span class="profile-badge mb-2 d-inline-block">Profil Klienta</span>
                    <h1 class="display-5 fw-bold text-white mb-3">@Model.Name</h1>
                    <div class="d-flex flex-column flex-md-row gap-3 mb-4">
                        <div class="d-flex align-items-center text-white-50">
                            <i class="bi bi-envelope-fill text-gold me-2"></i>
                            <span>@Model.Email</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                        {
                            <div class="d-flex align-items-center text-white-50">
                                <i class="bi bi-telephone-fill text-gold me-2"></i>
                                <span>@Model.PhoneNumber</span>
                            </div>
                        }
                    </div>

                </div>
            </div>
            <!-- Decorative scissors -->
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-scissors profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>

<!-- ===== QUICK ACCESS CARDS ===== -->
<section class="profile-section">
    <div class="container">
        <div class="section-header mb-5">
            <span class="section-tag">Twoje konto</span>
            <h2 class="section-title">Zarządzaj profilem</h2>
            <p class="text-muted">Szybki dostęp do wszystkich funkcji Twojego konta</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Zamówienia -->
            <div class="col-md-6 col-xl-3">
                <div class="profile-card service-card card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="profile-card__icon-wrap mb-3">
                            <i class="bi bi-bag-check-fill"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Moje Zamówienia</h5>
                        <p class="text-muted small mb-3">Historia i status realizacji</p>
                        <div class="profile-card__count mt-auto mb-3">@Model.OrdersCount</div>
                        <a asp-controller="Orders" asp-action="List" class="btn btn-gold w-100 rounded-pill">
                            Przegląd <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Wymiary -->
            <div class="col-md-6 col-xl-3">
                <div class="profile-card service-card card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="profile-card__icon-wrap mb-3">
                            <i class="bi bi-rulers"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Moje Wymiary</h5>
                        <p class="text-muted small mb-3">Zapisane wymiary ciała</p>
                        <div class="profile-card__count mt-auto mb-3">@Model.SizesCount</div>
                        <a asp-controller="Sizes" asp-action="List" class="btn btn-gold w-100 rounded-pill">
                            Przegląd <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Powiadomienia -->
            <div class="col-md-6 col-xl-3">
                <div class="profile-card service-card card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="profile-card__icon-wrap mb-3">
                            <i class="bi bi-bell-fill"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Powiadomienia</h5>
                        <p class="text-muted small mb-3">Aktualizacje i alerty konta</p>
                        <div class="mt-auto mb-3" style="height:2.5rem;"></div>
                        <a asp-controller="Notification" asp-action="Index" class="btn btn-outline-dark w-100 rounded-pill">
                            Sprawdź <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Ustawienia -->
            <div class="col-md-6 col-xl-3">
                <div class="profile-card service-card card h-100 border-0 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="profile-card__icon-wrap mb-3">
                            <i class="bi bi-gear-fill"></i>
                        </div>
                        <h5 class="fw-bold mb-1">Ustawienia</h5>
                        <p class="text-muted small mb-3">Dane osobowe i hasło</p>
                        <div class="mt-auto mb-3" style="height:2.5rem;"></div>
                        <a asp-controller="AccountSettings" asp-action="Index" class="btn btn-outline-dark w-100 rounded-pill">
                            Przejdź <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

