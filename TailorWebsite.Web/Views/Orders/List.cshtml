@using TailorWebsite.Model.DataModels
@model IEnumerable<TailorWebsite.ViewModels.VM.OrderCreateViewModel>
@{
    ViewData["Title"] = "Moje zamówienia";
    ViewData["FullWidth"] = true;

    string GetStatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "bg-warning text-dark",
        OrderStatus.InProgress => "bg-info text-dark",
        OrderStatus.Completed  => "bg-success",
        OrderStatus.Cancelled  => "bg-danger",
        _ => "bg-secondary"
    };

    string GetStatusName(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "Oczekujące",
        OrderStatus.InProgress => "W realizacji",
        OrderStatus.Completed  => "Zakończone",
        OrderStatus.Cancelled  => "Anulowane",
        _ => status.ToString()
    };
}

<!-- ===== HERO ===== -->
<section class="profile-hero">
    <div class="profile-hero__overlay"></div>
    <div class="container position-relative py-5" style="z-index:1;">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="profile-badge mb-3 d-inline-block">Historia i statusy</span>
                <h1 class="display-5 fw-bold text-white mb-3">Moje zamówienia</h1>
                <p class="text-white-50 mb-0">Śledź postępy zamówień i przeglądaj historię zleceń.</p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex justify-content-end align-items-center">
                <i class="bi bi-bag-check profile-hero__deco"></i>
            </div>
        </div>
    </div>
</section>

<!-- ===== CONTENT ===== -->
<section class="profile-section">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-3 shadow-sm border-0 mb-4 d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-3 shadow-sm border-0 mb-4 d-flex align-items-center">
                <i class="bi bi-exclamation-circle-fill me-2 fs-5"></i> @TempData["Error"]
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="section-tag">Twoje konto</span>
                <h2 class="section-title mb-0">Lista zamówień</h2>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-1"></i> Powrót
                </a>
                <a asp-controller="Orders" asp-action="Create" class="btn btn-gold rounded-pill px-4">
                    <i class="bi bi-plus-lg me-1"></i> Nowe zamówienie
                </a>
            </div>
        </div>

        <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var o in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="profile-card service-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4 d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge @GetStatusClass(o.Status) rounded-pill">@GetStatusName(o.Status)</span>
                                <span class="fw-bold fs-5">@o.TotalPrice PLN</span>
                            </div>

                            <h5 class="fw-bold mb-3">@o.Service?.Name</h5>

                            <div class="mb-4 d-flex flex-column gap-2">
                                <div class="d-flex align-items-center text-muted small">
                                    <i class="bi bi-calendar-event me-2 text-gold"></i>
                                    <span>Złożono: <strong>@o.OrderDate.ToString("dd.MM.yyyy")</strong></span>
                                </div>
                                <div class="d-flex align-items-center text-muted small">
                                    @if (o.UserPickupDate.HasValue)
                                    {
                                        <i class="bi bi-clock-history me-2 text-gold"></i>
                                        <span>Termin odbioru: <strong>@o.UserPickupDate.Value.ToString("dd.MM.yyyy")</strong></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-hourglass-split me-2 text-gold"></i>
                                        <span>Termin wyk.: <strong>@(o.OrderDueDate.HasValue ? o.OrderDueDate.Value.ToString("dd.MM.yyyy") : "Ustalamy...")</strong></span>
                                    }
                                </div>
                                <div class="d-flex align-items-center text-muted small">
                                    <i class="bi bi-layers me-2 text-gold"></i>
                                    <span>Ilość: <strong>@o.Quantity szt.</strong></span>
                                </div>
                            </div>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-outline-dark btn-sm flex-fill rounded-pill">
                                    Szczegóły
                                </a>
                                @if (o.Status == OrderStatus.Pending)
                                {
                                    <form asp-action="Cancel" method="post" class="flex-fill">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill"
                                                onclick="return confirm('Czy na pewno chcesz anulować to zamówienie?');">
                                            Anuluj
                                        </button>
                                    </form>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm text-center py-5 rounded-4">
                    <div class="card-body">
                        <div class="profile-card__icon-wrap mx-auto mb-4" style="width:5rem;height:5rem;font-size:2rem;">
                            <i class="bi bi-basket"></i>
                        </div>
                        <h3 class="fw-bold">Brak zamówień</h3>
                        <p class="text-muted mb-4">Nie masz jeszcze żadnych aktywnych ani archiwalnych zamówień.</p>
                        <a asp-controller="Orders" asp-action="Create" class="btn btn-gold px-4 py-2 rounded-pill">
                            Złóż pierwsze zamówienie
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>

    </div>
</section>

